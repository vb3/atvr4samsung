cmd_migrate_native() {
  local active='not-found'
  local enabled='not-found'
  local launcher='not-found'

  if command -v systemctl >/dev/null 2>&1; then
    if systemctl is-active atvr4samsung >/dev/null 2>&1; then
      active='active'
    else
      active='inactive'
    fi
    if systemctl is-enabled atvr4samsung >/dev/null 2>&1; then
      enabled='enabled'
    else
      enabled='disabled'
    fi
  fi

  if launcher=$(command -v atvr4samsung 2>/dev/null); then
    :
  else
    launcher='not-found'
  fi

  printf 'Native install discovery:\n'
  printf '  systemd active : %s\n' "$active"
  printf '  systemd enabled: %s\n' "$enabled"
  printf '  launcher       : %s\n' "$launcher"
  printf '\n'
  printf 'No changes were made. Review and run this migration manually:\n'
  printf '  1. Capture the current native config/state and stop using it for new changes.\n'
  printf '  2. If the native service is active, stop it yourself: sudo systemctl stop atvr4samsung\n'
  printf '  3. If the native service is enabled, disable it yourself after review: sudo systemctl disable atvr4samsung\n'
  printf '  4. Install the container bundle: %s install X.Y.Z\n' "$SELF_PATH"
  printf '  5. Review %s, run `%s trust-tv`, then `%s start`.\n' "$CONFIG_FILE" "$SELF_PATH" "$SELF_PATH"
  printf '  6. Remove old native launchers only after the container deployment is verified.\n'
}

main() {
  resolve_self
  resolve_deploy_paths

  local command=${1-}
  if [[ -z $command ]]; then
    usage >&2
    exit 64
  fi
  shift || true

  case "$command" in
    install)
      [[ $# -eq 1 ]] || fail 'install requires exactly one X.Y.Z version argument'
      with_lock cmd_install "$1"
      ;;
    upgrade)
      [[ $# -eq 1 ]] || fail 'upgrade requires exactly one X.Y.Z version argument'
      with_lock cmd_upgrade "$1"
      ;;
    rollback)
      [[ $# -eq 0 ]] || fail 'rollback does not accept extra arguments'
