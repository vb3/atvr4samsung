      ;;
    start)
      [[ $# -eq 0 ]] || fail 'start does not accept extra arguments'
      with_lock cmd_start
      ;;
    check)
      [[ $# -eq 0 ]] || fail 'check does not accept extra arguments'
      with_lock cmd_check
      ;;
    doctor)
      [[ $# -eq 0 ]] || fail 'doctor does not accept extra arguments'
      with_lock cmd_doctor
      ;;
    trust-tv)
      with_lock cmd_trust_tv "$@"
      ;;
    pair)
      with_lock cmd_pair "$@"
      ;;
    pairs)
      [[ $# -eq 0 ]] || fail 'pairs does not accept extra arguments'
      with_lock cmd_paired_device pairs
      ;;
    revoke)
      [[ $# -eq 1 ]] || fail 'revoke requires exactly one paired-device identifier'
      with_lock cmd_paired_device revoke "$1"
